{
  "lock": "deno.lock",
  "nodeModulesDir": "auto",
  "imports": {
    "@std/http": "jsr:@std/http@^1.1.0"
  },
  "tasks": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview --host 0.0.0.0",
    "start": "deno run --allow-env=PORT --allow-net --allow-read=dist server.ts"
  }
}
